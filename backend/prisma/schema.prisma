// Prisma schema - generado a partir del modelo logico acordado en el proyecto
// Ejecutar: npx prisma db pull   (si la BD ya existe con el script SQL de Enterprise Architect)
// o:        npx prisma migrate dev  (si se quiere que Prisma cree las tablas desde aqui)

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model Usuario {
  id_usuario  Int      @id @default(autoincrement())
  nombre      String   @db.VarChar(100)
  login       String   @unique @db.VarChar(50)
  contrasena  String   @db.VarChar(255)
  rol         String   @db.VarChar(20) // 'Administrador' | 'Vendedor'
  estado      Boolean  @default(true)

  ventas          Venta[]
  pedidos         Pedido[]
  alertas         Alerta[]
  reportes        ReporteVentas[]

  @@map("usuario")
}

model Categoria {
  id_categoria Int       @id @default(autoincrement())
  nombre       String    @unique @db.VarChar(50)
  productos    Producto[]

  @@map("categoria")
}

model Producto {
  id_producto        Int       @id @default(autoincrement())
  nombre             String    @db.VarChar(100)
  precio_compra      Decimal   @db.Decimal(10, 2)
  precio_venta       Decimal   @db.Decimal(10, 2)
  stock              Int       @default(0)
  stock_minimo       Int       @default(5)
  fecha_vencimiento  DateTime? @db.Date
  id_categoria       Int

  categoria          Categoria       @relation(fields: [id_categoria], references: [id_categoria])
  detallesVenta      DetalleVenta[]
  detallesPedido      DetallePedido[]
  alertas            Alerta[]

  @@map("producto")
}

model Cliente {
  id_cliente      Int     @id @default(autoincrement())
  nombre          String  @db.VarChar(100)
  telefono        String? @db.VarChar(20)
  numero_compras  Int     @default(0)
  puntos          Int     @default(0)
  ventas          Venta[]

  @@map("cliente")
}

model Venta {
  id_venta    Int      @id @default(autoincrement())
  fecha       DateTime @default(now())
  total       Decimal  @db.Decimal(10, 2)
  id_usuario  Int
  id_cliente  Int?

  usuario         Usuario              @relation(fields: [id_usuario], references: [id_usuario])
  cliente         Cliente?             @relation(fields: [id_cliente], references: [id_cliente])
  detalles        DetalleVenta[]
  reportesDetalle ReporteVentaDetalle[]

  @@map("venta")
}

model DetalleVenta {
  id_detalle       Int     @id @default(autoincrement())
  id_venta         Int
  id_producto      Int
  cantidad         Int
  precio_unitario  Decimal @db.Decimal(10, 2)
  subtotal         Decimal @db.Decimal(10, 2)

  venta    Venta    @relation(fields: [id_venta], references: [id_venta], onDelete: Cascade)
  producto Producto @relation(fields: [id_producto], references: [id_producto])

  @@map("detalle_venta")
}

model Proveedor {
  id_proveedor Int      @id @default(autoincrement())
  nombre       String   @db.VarChar(100)
  contacto     String?  @db.VarChar(100)
  pedidos      Pedido[]

  @@map("proveedor")
}

model Pedido {
  id_pedido     Int      @id @default(autoincrement())
  fecha         DateTime @default(now())
  estado        String   @db.VarChar(20) // 'Pendiente' | 'Recibido' | 'Cancelado'
  id_usuario    Int
  id_proveedor  Int

  usuario   Usuario         @relation(fields: [id_usuario], references: [id_usuario])
  proveedor Proveedor       @relation(fields: [id_proveedor], references: [id_proveedor])
  detalles  DetallePedido[]

  @@map("pedido")
}

model DetallePedido {
  id_detalle_pedido Int @id @default(autoincrement())
  id_pedido         Int
  id_producto       Int
  cantidad_pedida   Int

  pedido   Pedido   @relation(fields: [id_pedido], references: [id_pedido], onDelete: Cascade)
  producto Producto @relation(fields: [id_producto], references: [id_producto])

  @@map("detalle_pedido")
}

model Alerta {
  id_alerta         Int      @id @default(autoincrement())
  tipo              String   @db.VarChar(20) // 'StockBajo' | 'Vencimiento'
  fecha_generacion  DateTime @default(now())
  mensaje           String   @db.VarChar(255)
  id_producto       Int
  id_usuario        Int

  producto Producto @relation(fields: [id_producto], references: [id_producto], onDelete: Cascade)
  usuario  Usuario  @relation(fields: [id_usuario], references: [id_usuario])

  @@map("alerta")
}

model ReporteVentas {
  id_reporte        Int      @id @default(autoincrement())
  periodo           String   @db.VarChar(20) // 'Diario' | 'Semanal' | 'Mensual'
  fecha_generacion  DateTime @default(now())
  total_ventas      Decimal  @db.Decimal(10, 2)
  ganancia_total    Decimal  @db.Decimal(10, 2)
  id_usuario        Int

  usuario Usuario               @relation(fields: [id_usuario], references: [id_usuario])
  ventas  ReporteVentaDetalle[]

  @@map("reporte_ventas")
}

model ReporteVentaDetalle {
  id_reporte Int
  id_venta   Int

  reporte ReporteVentas @relation(fields: [id_reporte], references: [id_reporte], onDelete: Cascade)
  venta   Venta         @relation(fields: [id_venta], references: [id_venta])

  @@id([id_reporte, id_venta])
  @@map("reporte_venta_detalle")
}
